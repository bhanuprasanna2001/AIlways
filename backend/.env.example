# --------------------------------------------------------------
# AIlways - Environment Variables
# --------------------------------------------------------------

# Database
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydatabase
POSTGRES_PORT=5434
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
ASYNC_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# Pg Admin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# JWT Authentication
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis
REDIS_PASSWORD=mypassword
REDIS_PORT=6380
REDIS_SESSION_TTL_SECONDS=604800

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_QUERY_MODEL=gpt-4o-mini

# Deepgram
DEEPGRAM_API=your_deepgram_api_key
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=en

# Groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Claims pipeline
CLAIM_DETECTION_ENABLED=true
CLAIM_BATCH_INTERVAL_S=8.0
CLAIM_VERIFICATION_TOP_K=5

# LangSmith
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT_NAME=AIlways
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# Cohere (cross-encoder reranking)
COHERE_API_KEY=your_cohere_api_key

# File Storage
FILE_STORE_PATH=./data/uploads

# Ingestion
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=["pdf", "txt", "md"]

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_CONSUMER_GROUP=ailways-workers
KAFKA_ENABLED=true
KAFKA_PRODUCER_TIMEOUT_MS=10000
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=600000
KAFKA_RECOVERY_INTERVAL_MINUTES=5
